{
  "compilerOptions": {
    "checkJs": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@app/shared": ["packages/shared/typedefs.js"],
      "@app/permissions": ["packages/permissions/index.js"]
    }
  },
  "include": ["apps/**/*.js", "apps/**/*.jsx", "packages/**/*.js"],
  "exclude": ["node_modules", "dist", "apps/web/dist", "apps/server/dist"]
}

